{
  "templates": [
    {
      "id": "campaign-poster",
      "name": "品牌海报",
      "category": "poster-and-campaigns",
      "description": "适合联名款、主 KV、时尚广告、竖版视觉主图",
      "triggers": [
        "海报",
        "KV",
        "联名",
        "广告",
        "campaign",
        "poster",
        "主视觉"
      ],
      "required_focus": [
        "品牌气质",
        "文字留白",
        "场景分布",
        "全身或主视觉构图",
        "高质量商业摄影感"
      ],
      "ask_fields": [
        "品牌或联名关系",
        "海报用途与投放比例",
        "主体是人物、商品还是人物+商品",
        "是否需要预留标题、logo、slogan、安全区",
        "必须出现或必须避免的视觉元素"
      ],
      "required_slot_fields": [
        "style_family",
        "scene",
        "wardrobe",
        "composition",
        "lighting",
        "mood",
        "text_policy"
      ],
      "prompt_sections": [
        "subject_baseline",
        "campaign_intent",
        "scene_hierarchy",
        "wardrobe_product_focus",
        "pose_expression",
        "lighting_palette",
        "composition_layout",
        "typography_safe_area",
        "commercial_finish"
      ],
      "composition_bias": [
        "9:16 vertical hero poster, full-body or dominant subject, clear hierarchy",
        "reserved clean space for later logo, campaign claim, and co-branded lockup",
        "subject scale large enough for outdoor-ad or social-feed impact"
      ],
      "quality_rules": [
        "每条 prompt 必须明确海报用途，而不是普通写真",
        "场景必须有商业海报层级，不能只有白底或空背景",
        "服装或产品必须是可读的卖点，不要被姿势遮挡",
        "构图必须说明全身、半身或主视觉裁切规则",
        "文字安全区只描述留白，不让模型直接生成可读文字"
      ],
      "default_negative_terms": [
        "watermark",
        "readable text",
        "fake logo",
        "cropped feet",
        "cheap catalog look",
        "plain empty background",
        "busy typography",
        "low-detail fabric"
      ],
      "anti_patterns": [
        "把主 KV 写成普通棚拍人像",
        "没有场景层级，只剩白底人物",
        "生成真实品牌 logo 或可读商标文字",
        "全身海报却裁掉脚或手",
        "同一批 prompt 只替换少量形容词"
      ],
      "template_doc": "references/templates/poster-and-campaigns/campaign-poster.md",
      "variants": [
        {
          "id": "co-brand-kv",
          "name": "联名主 KV",
          "description": "双方品牌调性同屏，主视觉强，预留联名锁定区"
        },
        {
          "id": "product-hero",
          "name": "产品主视觉",
          "description": "商品和材质可读性优先"
        },
        {
          "id": "people-hero",
          "name": "人物主视觉",
          "description": "人物眼神、姿态、品牌气质优先"
        },
        {
          "id": "campaign-extension",
          "name": "Campaign 延展",
          "description": "同一视觉系统下多场景扩展"
        }
      ],
      "default_variant_axes": [
        {
          "name": "camera-language",
          "field": "camera_language",
          "strategy": "cycle",
          "batch_balance": "within-batch",
          "options": [
            "full-body vertical hero framing",
            "walking turn-back poster motion",
            "subtle low-angle fashion perspective"
          ]
        },
        {
          "name": "commercial-role",
          "field": "commercial_role",
          "strategy": "cycle",
          "options": [
            "master KV",
            "product-benefit poster",
            "campaign extension visual"
          ]
        }
      ],
      "autofill_policy": {
        "enabled": true,
        "mark_sources": true,
        "rules": [
          {
            "field": "lighting",
            "values": [
              "soft premium studio light",
              "directional rim light",
              "diffused window light"
            ],
            "source": "template-autofill"
          },
          {
            "field": "mood",
            "values": [
              "expensive restraint",
              "calm luxury",
              "editorial confidence"
            ],
            "source": "template-autofill"
          }
        ]
      }
    },
