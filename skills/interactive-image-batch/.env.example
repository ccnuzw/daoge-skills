# DAOGE 图片 provider 配置模板。
# 复制为 .env 后，只填写计划使用的 provider。
# 真实 key 不要写入代码、测试、文档或提交历史。

# provider 选择。
# 支持：openai-images, gemini-image, gemini-openai-compatible, xai-grok-image
# 别名：
# - openai, gpt-image, gpt-image-2 -> openai-images
# - gemini, gemini-images -> gemini-image
# - gemini-openai, gemini-oai -> gemini-openai-compatible
# - grok-image, xai-image -> xai-grok-image
IMAGE_PROVIDER=openai-images

# OpenAI Images provider。
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-image-2
OPENAI_RESPONSES_MODEL=gpt-5.4
OPENAI_IMAGE_GENERATE_PATH=
OPENAI_IMAGE_EDIT_PATH=

# Gemini 原生 generateContent provider。
# 注意：仅在目标 endpoint/proxy 确认可用后使用。
GEMINI_IMAGE_BASE_URL=
GEMINI_IMAGE_API_KEY=
GEMINI_IMAGE_MODEL=
GEMINI_IMAGE_GENERATE_PATH=
GEMINI_IMAGE_AUTH_MODE=x-goog-api-key
GEMINI_IMAGE_ENABLE_REFERENCE=0
GEMINI_IMAGE_MAX_RESPONSE_BYTES=134217728

# Gemini OpenAI-compatible Images provider。
GEMINI_OPENAI_BASE_URL=
GEMINI_OPENAI_API_KEY=
GEMINI_OPENAI_MODEL=
GEMINI_OPENAI_IMAGE_GENERATE_PATH=
GEMINI_OPENAI_AUTH_MODE=bearer
GEMINI_OPENAI_MAX_RESPONSE_BYTES=134217728
GEMINI_OPENAI_MAX_DOWNLOAD_BYTES=67108864

# xAI/Grok 图片 provider。
XAI_IMAGE_BASE_URL=https://api.x.ai/v1
XAI_IMAGE_API_KEY=
XAI_IMAGE_MODEL=grok-imagine-image-quality
XAI_IMAGE_GENERATE_PATH=
XAI_IMAGE_RESPONSE_FORMAT=
XAI_IMAGE_MAX_RESPONSE_BYTES=134217728
XAI_IMAGE_MAX_DOWNLOAD_BYTES=67108864
